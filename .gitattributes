# Normalize line endings on checkin
* text=auto eol=lf

# ═════════════════════════════════════════════════════════════════════════════
# Source files — text with LF endings
# ═════════════════════════════════════════════════════════════════════════════
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.cjs      text eol=lf
*.mjs      text eol=lf
*.json     text eol=lf
*.jsonc    text eol=lf
*.rs       text eol=lf
*.toml     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.zig      text eol=lf
*.c        text eol=lf
*.h        text eol=lf
*.cpp      text eol=lf
*.hpp      text eol=lf

# Shell scripts must be LF
*.sh       text eol=lf
*.bash     text eol=lf

# Windows scripts must be CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# ═════════════════════════════════════════════════════════════════════════════
# Binary files — never modify
# ═════════════════════════════════════════════════════════════════════════════
*.node     binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.svg      text eol=lf

# Audio/video fixtures for libopus tests
*.opus     binary
*.ogg      binary
*.wav      binary
*.mp3      binary
*.flac     binary
*.pcm      binary
*.raw      binary

# Compressed
*.gz       binary
*.tar      binary
*.zip      binary

# ═════════════════════════════════════════════════════════════════════════════
# Exclude from language stats / npm tarball / GitHub linguist
# ═════════════════════════════════════════════════════════════════════════════

# libopus vendored sources — third-party, exclude from GitHub language stats
vendor/libopus/**          linguist-vendored
vendor/libopus/**/*.c      linguist-vendored
vendor/libopus/**/*.h      linguist-vendored

# Generated files
dist/**                    linguist-generated
target/**                  linguist-generated
zig-out/**                 linguist-generated

# Documentation
docs/**                    linguist-documentation
*.md                       linguist-documentation

# Tests don't count toward language stats
__tests__/**               linguist-detectable=false

# ═════════════════════════════════════════════════════════════════════════════
# npm tarball — exclude from `npm pack` (alternative to .npmignore for some)
# Note: actual exclusion happens via .npmignore + "files" in package.json
# ═════════════════════════════════════════════════════════════════════════════

# GitHub diff config — collapse vendored files in diffs
vendor/libopus/** -diff
package-lock.json -diff
Cargo.lock        -diff

# Detect files for export-ignore (used when downloading "tarball" from GitHub)
.github/                   export-ignore
__tests__/                 export-ignore
examples/                  export-ignore
.editorconfig              export-ignore
.eslintrc.json             export-ignore
.gitattributes             export-ignore
.gitignore                 export-ignore
.prettierrc                export-ignore
