# ═════════════════════════════════════════════════════════════════════════════
# .gitignore for @kryxjs/codecs-opus
#
# Rule: SOURCE CODE STAYS TRACKED, BUILD OUTPUT DOES NOT.
# This applies to Rust, TypeScript, Zig, and the vendored libopus C sources.
# ═════════════════════════════════════════════════════════════════════════════

# ─── Rust build artifacts ──────────────────────────────────────────────────
/target
**/*.rs.bk
*.pdb

# ─── TypeScript / Node build artifacts ─────────────────────────────────────
/dist
node_modules/
*.tsbuildinfo
.eslintcache

# ─── Native binaries (produced by napi-rs) ─────────────────────────────────
*.node

# ─── Per-platform npm sub-packages (regenerated by scripts/create-npm-dirs.js) ─
/npm

# ─── Zig build artifacts ───────────────────────────────────────────────────
/zig-out
/.zig-cache

# ═════════════════════════════════════════════════════════════════════════════
# libopus build artifacts
# IMPORTANT: vendor/libopus/ SOURCES stay tracked. Only build outputs are ignored.
# ═════════════════════════════════════════════════════════════════════════════

# autoconf/automake generated outputs
vendor/libopus/autom4te.cache/
vendor/libopus/config.log
vendor/libopus/config.status
vendor/libopus/config.h
vendor/libopus/config.h.in~
vendor/libopus/configure
vendor/libopus/Makefile
vendor/libopus/Makefile.in
vendor/libopus/aclocal.m4
vendor/libopus/libtool
vendor/libopus/.libs/
vendor/libopus/.deps/
vendor/libopus/stamp-h*
vendor/libopus/INSTALL
vendor/libopus/compile
vendor/libopus/depcomp
vendor/libopus/install-sh
vendor/libopus/missing
vendor/libopus/test-driver
vendor/libopus/ltmain.sh

# CMake build dir (when anyone runs cmake locally)
vendor/libopus/build/
vendor/libopus/build-*/
vendor/libopus/CMakeFiles/
vendor/libopus/CMakeCache.txt
vendor/libopus/cmake_install.cmake

# Meson build dir
vendor/libopus/builddir/
vendor/libopus/build-meson/

# Compiled objects (any platform)
vendor/libopus/**/*.o
vendor/libopus/**/*.obj
vendor/libopus/**/*.lo
vendor/libopus/**/*.la
vendor/libopus/**/*.a
vendor/libopus/**/*.lib
vendor/libopus/**/*.so
vendor/libopus/**/*.so.*
vendor/libopus/**/*.dylib
vendor/libopus/**/*.dll
vendor/libopus/**/*.exp
vendor/libopus/**/*.pdb

# Pre-trained DNN models (downloaded on demand by libopus dnn/download_model.bat)
vendor/libopus/dnn/models/

# Generated Opus binaries (if anyone runs make)
vendor/libopus/opus_demo
vendor/libopus/opus_demo.exe
vendor/libopus/opus_compare
vendor/libopus/opus_compare.exe
vendor/libopus/repacketizer_demo
vendor/libopus/repacketizer_demo.exe

# pkg-config output
vendor/libopus/opus.pc
vendor/libopus/opus-uninstalled.pc

# ═════════════════════════════════════════════════════════════════════════════
# Lock files
# Decision: NOT tracked. Re-resolve dependencies on each install for libs.
# (If you want reproducible installs, remove these two lines and commit them.)
# ═════════════════════════════════════════════════════════════════════════════
package-lock.json
Cargo.lock
yarn.lock
pnpm-lock.yaml

# ═════════════════════════════════════════════════════════════════════════════
# Test coverage
# ═════════════════════════════════════════════════════════════════════════════
/coverage
*.profraw
*.profdata
lcov.info
.nyc_output/

# ═════════════════════════════════════════════════════════════════════════════
# Editors / IDEs
# ═════════════════════════════════════════════════════════════════════════════

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*.swn
*~
\#*\#
.\#*

# Sublime
*.sublime-project
*.sublime-workspace

# ═════════════════════════════════════════════════════════════════════════════
# Operating system noise
# ═════════════════════════════════════════════════════════════════════════════

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ═════════════════════════════════════════════════════════════════════════════
# Environment / Secrets
# ═════════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
.envrc

# ═════════════════════════════════════════════════════════════════════════════
# Logs
# ═════════════════════════════════════════════════════════════════════════════
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ═════════════════════════════════════════════════════════════════════════════
# Profiling / Benchmarks output
# ═════════════════════════════════════════════════════════════════════════════
flamegraph.svg
perf.data
perf.data.old

# ═════════════════════════════════════════════════════════════════════════════
# Local scratch / experiments
# ═════════════════════════════════════════════════════════════════════════════
.scratch/
*.local.md
TODO.local.md
NOTES.local.md