# ═════════════════════════════════════════════════════════════════════════════
# .gitignore for @kryxjs/codecs-opus
#
# Rule: SOURCE CODE STAYS TRACKED, BUILD OUTPUT DOES NOT.
# ═════════════════════════════════════════════════════════════════════════════

# ─── Rust build artifacts ──────────────────────────────────────────────────
/target
**/*.rs.bk
*.pdb

# ─── TypeScript / Node build artifacts ─────────────────────────────────────
/dist
node_modules/
*.tsbuildinfo
.eslintcache

# ─── Native binaries (produced by napi-rs) ─────────────────────────────────
*.node

# ─── Per-platform npm sub-packages ─────────────────────────────────────────
/npm

# ═════════════════════════════════════════════════════════════════════════════
# Zig build artifacts — CRITICAL: never commit these
# The .zig-cache directory contains thousands of intermediate build files.
# Only zig/build.zig and zig/src/*.c are source and stay tracked.
# ═════════════════════════════════════════════════════════════════════════════
zig-out/
.zig-cache/
/zig/zig-out
/zig/.zig-cache
**/zig-out/
**/.zig-cache/

# ═════════════════════════════════════════════════════════════════════════════
# libopus build artifacts (sources under vendor/libopus/ STAY tracked)
# ═════════════════════════════════════════════════════════════════════════════
vendor/libopus/**/*.o
vendor/libopus/**/*.obj
vendor/libopus/**/*.a
vendor/libopus/**/*.lib
vendor/libopus/**/*.lo
vendor/libopus/**/*.la
vendor/libopus/**/*.so
vendor/libopus/**/*.dylib
vendor/libopus/**/*.dll
vendor/libopus/.libs/
vendor/libopus/.deps/
vendor/libopus/autom4te.cache/
vendor/libopus/config.log
vendor/libopus/config.status
vendor/libopus/Makefile
vendor/libopus/build/
vendor/libopus/CMakeFiles/
vendor/libopus/CMakeCache.txt

# ═════════════════════════════════════════════════════════════════════════════
# Lock files (not tracked by convention for this ecosystem)
# ═════════════════════════════════════════════════════════════════════════════
package-lock.json
Cargo.lock
yarn.lock
pnpm-lock.yaml

# ═════════════════════════════════════════════════════════════════════════════
# Test coverage
# ═════════════════════════════════════════════════════════════════════════════
/coverage
*.profraw
*.profdata
lcov.info
.nyc_output/

# ═════════════════════════════════════════════════════════════════════════════
# Editors / IDEs
# ═════════════════════════════════════════════════════════════════════════════
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.iml
*.swp
*.swo
*~

# ═════════════════════════════════════════════════════════════════════════════
# OS noise
# ═════════════════════════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/
.directory
.Trash-*

# ═════════════════════════════════════════════════════════════════════════════
# Environment / Secrets
# ═════════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
.envrc

# ═════════════════════════════════════════════════════════════════════════════
# Logs
# ═════════════════════════════════════════════════════════════════════════════
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ═════════════════════════════════════════════════════════════════════════════
# Local scratch
# ═════════════════════════════════════════════════════════════════════════════
.scratch/
*.local.md
fix-tests-m2.js